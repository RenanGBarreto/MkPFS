###############################################################################
# Custom ignore rules
###############################################################################

# Claude settings
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/rules/
!.claude/rules/**
!.claude/MEMORY.md
!.claude/settings.json

# Editor / local config
.idea/
.copier-answers.yml
.env
.env.*
*.local
*.secret
*.key
*.pem
*.crt
*.p12
*.jks
*.token
*.cred
*.bak
*.orig
*.rej
.envrc
.direnv/
.pypirc
.netrc
.npmrc
.aws/
.ruff_cache/

# Related project files
/related-projects/*
!/related-projects/shadowmountplus
!/related-projects/pkgtool
!/related-projects/liborbispkg
!/related-projects/liborbispkg-wiki
!/related-projects/*.md

# Temporary files and scratch artifacts
/tmp/*
/.tmp*
.tmp-*
*.tmp
!/tmp/.gitkeep

# Unit tests
unit.xml
coverage.xml

# End of Custom rules
